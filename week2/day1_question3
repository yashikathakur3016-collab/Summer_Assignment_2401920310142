class Solution {
public:
    bool canConstruct(string s1, string s2) {
        unordered_map<char,int> mp;
        for(char c : s2){
            mp[c]++;
        }        
        for(char c:s1){
            if(mp[c]==0)
            return false;
            mp[c]--;
        }
        return true;
    }
};
